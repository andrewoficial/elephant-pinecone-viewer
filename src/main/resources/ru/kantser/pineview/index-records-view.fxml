<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.kantser.pineview.ui.IndexRecordsWindow"
            stylesheets="@styles.css"
            minWidth="900" minHeight="600">

    <!-- Заголовок -->
    <top>
        <VBox spacing="8" styleClass="panel-header">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="indexNameLabel" styleClass="panel-title"/>
                <Label fx:id="recordCountLabel" styleClass="panel-subtitle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↻ Refresh" onAction="#handleRefresh" styleClass="btn-small"/>
                <Button text="➕ Add Record" onAction="#handleAddRecord" styleClass="btn-primary"/>
            </HBox>
            <TextField fx:id="searchField" promptText="🔍 Search by ID or metadata..."
                       onAction="#handleSearch" styleClass="search-field"/>
        </VBox>
    </top>

    <!-- Таблица записей -->
    <center>
        <TableView fx:id="recordsTable" styleClass="data-table" VBox.vgrow="ALWAYS">
            <!-- Убираем политику авторесайза, используем жесткие размеры из Java кода -->
            <columns>
                <TableColumn text="ID" fx:id="colId"/>
                <TableColumn text="Text Preview" fx:id="colText"/>
                <TableColumn text="Metadata" fx:id="colMetadata"/>
                <TableColumn text="Actions" fx:id="colActions"/>
            </columns>
        </TableView>
    </center>

    <!-- Детали выбранной записи -->
    <bottom>
        <VBox spacing="0">
            <Separator styleClass="separator" />

            <!-- Панель-заглушка -->
            <VBox fx:id="placeholderPanel" spacing="12" styleClass="detail-panel-placeholder" visible="true" managed="true">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>
                <Label text="Select a record to view details" styleClass="placeholder-text" alignment="CENTER" maxWidth="Infinity"/>
            </VBox>

            <!-- Панель деталей -->
            <!-- Добавляем alignment="CENTER" чтобы содержимое центрировалось -->
            <VBox fx:id="detailPanel" spacing="12" styleClass="detail-panel" visible="false" managed="false" alignment="CENTER">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <!-- Ограничиваем ширину содержимого, чтобы оно не растягивалось на весь экран -->
                <VBox spacing="10" maxWidth="800" styleClass="detail-content-wrapper">
                    <Label text="📋 Record Details" styleClass="detail-title"/>

                    <GridPane hgap="12" vgap="8" alignment="CENTER">
                        <!-- Центрируем контент в ячейках -->
                        <Label text="ID:" styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.halignment="RIGHT"/>
                        <Label fx:id="detailId" styleClass="detail-value" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.halignment="LEFT"/>
                        <Button text="📋 Copy" onAction="#copyId" styleClass="btn-tiny" GridPane.rowIndex="0" GridPane.columnIndex="2"/>

                        <Label text="Text:" styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="TOP" GridPane.halignment="RIGHT"/>
                        <!-- Задаем предпочтительную ширину, чтобы блок был аккуратным -->
                        <TextArea fx:id="detailText" editable="false" wrapText="true"
                                  prefHeight="150" prefWidth="700" styleClass="detail-textarea"
                                  GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="2"/>

                        <Label text="Meta" styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.valignment="TOP" GridPane.halignment="RIGHT"/>
                        <TextArea fx:id="detailMetadata" editable="false" wrapText="true"
                                  prefHeight="100" prefWidth="700" styleClass="detail-textarea"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="2"/>

                        <Label text="Vector:" styleClass="detail-label" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.halignment="RIGHT"/>
                        <HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="2">
                            <Label fx:id="vectorSummary" styleClass="detail-value"/>
                            <Button fx:id="toggleVectorBtn" text="▼ Show" onAction="#toggleVector" styleClass="btn-tiny"/>
                        </HBox>
                        <TextArea fx:id="detailVector" visible="false" editable="false" wrapText="false"
                                  prefHeight="80" prefWidth="700" styleClass="detail-textarea mono-font"
                                  GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="2"/>
                    </GridPane>

                    <!-- Кнопки выровнены по центру справа внутри ограниченного блока -->
                    <HBox spacing="8" alignment="CENTER_RIGHT">
                        <Button text="✏️ Edit" onAction="#handleEditSelected" styleClass="btn-secondary"/>
                        <Button text="🗑️ Delete" onAction="#handleDeleteSelected" styleClass="btn-danger"/>
                        <Button text="Close" onAction="#handleClose" styleClass="btn-small"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </bottom>

</BorderPane>