<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.kantser.pineview.ui.IndexRecordsWindow"
            stylesheets="@styles.css"
            minWidth="800" minHeight="400">

    <!-- Заголовок -->
    <top>
        <VBox spacing="4" styleClass="panel-header">
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="indexNameLabel" styleClass="panel-title"/>
                <Label fx:id="recordCountLabel" styleClass="panel-subtitle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📂 Import" onAction="#handleImport" styleClass="btn-secondary"/>
                <Button text="↻" onAction="#handleRefresh" styleClass="btn-small"/>
                <Button text="➕ Add" onAction="#handleAddRecord" styleClass="btn-primary"/>
            </HBox>

            <TextField fx:id="searchField" promptText="🔍 Search by ID or metadata..."
                       onAction="#handleSearch" styleClass="search-field"/>
        </VBox>
    </top>

    <!-- Таблица записей -->
    <center>
        <TableView fx:id="recordsTable" styleClass="data-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="ID" fx:id="colId"/>
                <TableColumn text="Text Preview" fx:id="colText"/>
                <TableColumn text="Metadata" fx:id="colMetadata"/>
                <TableColumn text="Act" fx:id="colActions"/>
            </columns>
        </TableView>
    </center>

    <!-- Детали выбранной записи -->
    <bottom>
        <VBox spacing="0">
            <Separator styleClass="separator" />

            <!-- Панель-заглушка -->
            <VBox fx:id="placeholderPanel" spacing="8" styleClass="detail-panel-placeholder" visible="true" managed="true" maxHeight="50">
                <padding>
                    <Insets top="8" right="16" bottom="8" left="16"/>
                </padding>
                <Label text="Select a record to view details" styleClass="placeholder-text" alignment="CENTER" maxWidth="Infinity"/>
            </VBox>

            <!-- Панель деталей -->
            <VBox fx:id="detailPanel" styleClass="detail-panel" visible="false" managed="false" VBox.vgrow="NEVER">
                <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="detail-scroll-pane">
                    <VBox spacing="8">
                        <padding>
                            <Insets top="8" right="12" bottom="8" left="12"/>
                        </padding>

                        <!-- Верхняя строка: ID и Кнопки действий -->
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 4 0;">
                            <Label text="ID:" styleClass="detail-label"/>
                            <Label fx:id="detailId" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
                            <Button text="📋" onAction="#copyId" styleClass="btn-tiny"/>
                            <Button text="✏️ Edit" onAction="#handleEditSelected" styleClass="btn-secondary-tiny"/>
                            <Button text="🗑️ Delete" onAction="#handleDeleteSelected" styleClass="btn-danger-tiny"/>
                            <Button text="✖ Close" onAction="#handleClose" styleClass="btn-small"/>
                        </HBox>

                        <!-- Основной текст (на всю ширину) -->
                        <TextArea fx:id="detailText" editable="false" wrapText="true"
                                  prefHeight="100" styleClass="detail-textarea"
                                  VBox.vgrow="ALWAYS"/>

                        <!-- Спойлер для Меты и Вектора (ИСПРАВЛЕНО: убран fx:define) -->
                        <VBox spacing="4">
                            <Button fx:id="toggleMetaVectorBtn" text="▼ Show details" onAction="#toggleMetaVector" styleClass="btn-spoiler"/>

                            <!-- Контейнер для Меты и Вектора (скрыт по умолчанию) -->
                            <HBox fx:id="metaVectorBox" spacing="10" visible="false" managed="false">
                                <!-- Левая колонка: Мета -->
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Metadata" styleClass="detail-label-mini"/>
                                    <TextArea fx:id="detailMetadata" editable="false" wrapText="true"
                                              prefHeight="60" styleClass="detail-textarea compact-meta"
                                              VBox.vgrow="ALWAYS"/>
                                </VBox>

                                <!-- Правая колонка: Вектор -->
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label fx:id="vectorSummary" styleClass="detail-label-mini"/>
                                    <TextArea fx:id="detailVector" editable="false" wrapText="false"
                                              prefHeight="60" styleClass="detail-textarea compact-meta mono-font"
                                              VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </HBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>
        </VBox>
    </bottom>

</BorderPane>